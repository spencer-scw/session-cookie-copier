{
  "manifest_version": 3,
  "name": "Session Cookie Copier",
  "version": "1.0",
  "description": "Copy the __session cookie to clipboard",
  "permissions": ["cookies", "activeTab", "scripting", "offscreen", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}